#include<stdio.h>
#define MAX 100

int arr[MAX];
int n = 0;

void insert(int value){
    if(n>= MAX){
        printf("the array is full");
    }
    else{
        arr[n]=value;
        n++;
    }
}

void delete(int value){
    int i,j;
    for(i=0;i<n;i++){
        if(arr[i]==value){
            for(j=i;j<n-1;j++){
                arr[j]=arr[j+1];
            }
            n--;
            printf("element deleted\n");
            return;
        }
    }
    printf("element not found\n");
}
void display(){
    if(n==0){
        printf("the array is empty");

    }else{
        printf("the elements are:\n");
        for( int i=0;i<n;i++){
            printf("%d\n ",arr[i]);
            //i++;(for getting tottal value of stored value of array)
        }
    }
}
int main(){
    insert(5);
    insert(6);
    insert(7);
    insert(8);
    delete(6);
    display();
    return 0;
}
